# Mobile App Environment Variables
EXPO_PUBLIC_API_URL=https://saluslogica-api-c5sl.onrender.com/api

# Firebase Configuration (if using push notifications)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456789

# OpenFDA API Key (for medicine search)
EXPO_PUBLIC_OPENFDA_API_KEY=your-openfda-api-key
