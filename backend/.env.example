# Environment variables for SalusLogica Backend
# Copy this file to .env and configure with your values
# DO NOT commit .env to version control!

# Django settings
DEBUG=True
SECRET_KEY=django-insecure-your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver

# Database configuration
# For development (SQLite) - default
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=db.sqlite3
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=

# For production (PostgreSQL) - uncomment and configure:
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=saluslogica
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-secure-password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Redis/Celery configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email configuration
# For development/testing (console output):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production (Brevo SMTP):
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-brevo-smtp-login
EMAIL_HOST_PASSWORD=your-brevo-smtp-password
DEFAULT_FROM_EMAIL=YourApp <your-email@example.com>

# Alternative (Gmail):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# CORS settings (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:8000,http://127.0.0.1:8000

# Time Zone
TIME_ZONE=UTC

# AWS S3 Configuration (for production media storage)
# Set USE_S3=True to enable AWS S3 for avatar uploads and other media
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/django.log

# Security settings for production (only applies when DEBUG=False)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# API Rate Limiting (requests per time period)
# Format: number/period where period is: second, minute, hour, day
# Adjust these values based on your traffic patterns and server capacity
ANON_BURST_RATE=20/min
ANON_SUSTAINED_RATE=100/hour
USER_BURST_RATE=60/min
USER_SUSTAINED_RATE=1000/hour
PHARMACY_ADMIN_RATE=2000/hour
LOGIN_RATE=5/min
PASSWORD_RESET_RATE=3/hour
REGISTRATION_RATE=3/hour
MEDICINE_CREATION_RATE=30/hour
NOTIFICATION_RATE=100/hour
UPLOAD_RATE=20/hour
