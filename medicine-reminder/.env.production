# Production Environment Variables for Vercel
# These will be overridden by Vercel Dashboard Environment Variables

# Backend API URL - UPDATE THIS AFTER RENDER DEPLOYMENT
VITE_API_URL=https://saluslogica-api-c5sl.onrender.com/api

# WebSocket URL (optional)
VITE_WS_URL=wss://saluslogica-api-c5sl.onrender.com/ws

# Environment
VITE_ENV=production

# Disable debug mode
VITE_DEBUG=false

# Timezone
VITE_TIMEZONE=Africa/Kigali

# Notification settings
VITE_ENABLE_NOTIFICATIONS=true
VITE_NOTIFICATION_SOUND=true

# Analytics settings
VITE_ENABLE_ANALYTICS=true
VITE_TRACKING_ID=

# Feature flags
VITE_ENABLE_CHATBOT=true
VITE_ENABLE_VOICE_NOTIFICATIONS=true
VITE_ENABLE_OFFLINE_MODE=true

# API timeout settings (in milliseconds)
VITE_API_TIMEOUT=30000
VITE_RETRY_ATTEMPTS=3

# Cache settings
VITE_ENABLE_CACHE=true
VITE_CACHE_DURATION=300000

# Security settings
VITE_ENABLE_CSRF=true
VITE_REQUIRE_HTTPS=true
